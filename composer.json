{
    "name": "psc-acme/wrapper-shipping",
    "description": "Package wrapper-shipping for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\WrapperShipping\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "brick/date-time": "^0.7.1",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "symfony/process": "^7.0",
        "symfony/uid": "^7.0",
        "psc-acme/validator-cart": "^1.0"
    },
    "require-dev": {
        "infection/infection": "^0.27"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}